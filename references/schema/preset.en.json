          "additionalProperties": false
        },
        "destination": {
          "type": "object",
          "properties": {
            "display": {
              "type": "boolean"
            },
            "prompt": {
              "type": "boolean"
            }
          },
          "required": [
            "display",
            "prompt"
          ],
          "additionalProperties": false
        },
        "run_on_edit": {
          "type": "boolean"
        },
        "min_depth": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "max_depth": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "script_name",
        "enabled",
        "find_regex",
        "source",
        "destination"
      ],
      "additionalProperties": false
    },
    "__schema41": {
