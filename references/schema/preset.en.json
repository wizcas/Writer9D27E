      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "__schema37": {
      "type": "object",
      "properties": {
        "folder": {
          "type": "string"
        },
        "entries": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/__schema13"
              },
              {
                "$ref": "#/$defs/__schema37"
              }
            ]
          }
        }
      },
      "required": [
        "folder",
        "entries"
      ]
    },
    "__schema38": {
      "$ref": "#/$defs/__schema12"
    },
    "__schema39": {
      "type": "object",
      "properties": {
        "regex_scripts": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema40"
          }
        },
        "tavern_helper": {
          "default": {},
          "type": "object",
          "properties": {
            "scripts": {
              "default": [],
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "$ref": "#/$defs/__schema44"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "id": {
                        "default": "63a901c0-c7d8-4f99-8983-fe22ca3de636",
                        "type": "string"
                      },
                      "enabled": {
                        "type": "boolean"
                      },
                      "type": {
                        "type": "string",
                        "const": "folder"
                      },
                      "icon": {
                        "default": "fa-solid fa-folder",
                        "type": "string"
                      },
                      "color": {
                        "default": "rgba(219, 219, 214, 1)",
                        "type": "string"
                      },
                      "scripts": {
                        "default": [],
                        "type": "array",
                        "items": {
                          "$ref": "#/$defs/__schema44"
                        }
                      }
                    },
                    "required": [
                      "name",
                      "enabled",
                      "type"
                    ],
                    "additionalProperties": false
                  }
                ]
              }
            },
            "variables": {
              "default": {},
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": {}
    },
    "__schema40": {
